AddDefaultCharset UTF-8
Options -Indexes

ErrorDocument 404 /404.html

RewriteEngine On

# presmerovani na https + www (kanonicka adresa)
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.m-studiobeauty\.cz$ [NC]
RewriteRule ^(.*)$ https://www.m-studiobeauty.cz/$1 [R=301,L]

# zrusene stranky rezervacniho systemu
Redirect 301 /panel-zakaznika/ https://www.m-studiobeauty.cz/kontakt/
Redirect 301 /panel-masera/ https://www.m-studiobeauty.cz/kontakt/

# stare wordpress obrazky -> nova slozka assets
RedirectMatch 301 ^/wp-content/uploads/2025/04/Cenik-procedur.*$ /assets/img/cenik-procedur-848.jpg
RedirectMatch 301 ^/wp-content/uploads/2025/04/Cenik-pernamentky.*$ /assets/img/cenik-permanentky-848.jpg
RedirectMatch 301 ^/wp-content/.*$ /

<IfModule mod_expires.c>
    ExpiresActive On
    # Obrazky a fonty jsou statické (pri zmene se nahrava novy soubor) → dlouha cache
    # (doporuceni PageSpeed "efficient cache policy"). Pri vymene obrazku pod stejnym
    # nazvem je treba na hostingu vycistit cache nebo pouzit novy nazev souboru.
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
